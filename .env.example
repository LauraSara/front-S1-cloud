# VitalGuard Frontend - Variables de configuración
# Copiar a environment.ts / environment.docker.ts según el entorno

# URL base del BFF (Spring Boot)
API_URL=http://localhost:8080/api

# Azure AD / Microsoft Entra ID
AZURE_CLIENT_ID=TU_CLIENT_ID
AZURE_TENANT_ID=TU_TENANT_ID
AZURE_AUTHORITY=https://login.microsoftonline.com/TU_TENANT_ID
AZURE_REDIRECT_URI=http://localhost:4200
AZURE_BFF_SCOPE=api://BFF_CLIENT_ID/access_as_user

# Docker Lab (producción)
# API_URL=https://bff-xxxxx.dockerlab.duoc.cl/api
# AZURE_REDIRECT_URI=https://frontend-xxxxx.dockerlab.duoc.cl

# Polling (milisegundos)
POLLING_INTERVAL_VITALS=5000
POLLING_INTERVAL_DASHBOARD=10000
